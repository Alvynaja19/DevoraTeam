# ==============================================================
# .dockerignore — Exclude files from Docker build context
# ==============================================================

# Dependencies (will be installed inside container)
node_modules/
vendor/

# Git
.git/
.gitignore
.gitattributes

# Development files
.env
.env.*
!.env.example

# Logs
storage/logs/*.log
*.log

# Test files
tests/
phpunit.xml

# Dev tools
.editorconfig
PLANING/
README.md

# Local database files (tidak perlu masuk ke image)
database/database.sqlite
database/*.sqlite

# Build artifacts (rebuilt inside container)
public/hot

# Docker files (not needed inside image)
docker/
docker-compose*.yml
Dockerfile

# IDE files
.idea/
.vscode/
*.swp
*.swo
